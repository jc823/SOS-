# ─── Database ─────────────────────────────────────────────────────────────────
# TiDB / MySQL connection string
DATABASE_URL=mysql://user:password@host:4000/dbname?ssl={"rejectUnauthorized":true}

# ─── Auth ─────────────────────────────────────────────────────────────────────
SESSION_SECRET=your-secure-random-secret-at-least-32-chars
OWNER_OPEN_ID=owner

# ─── AI / LLM (pick one) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# ─── S3 Storage (for logo uploads) ───────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1

# ─── Sales Arena Integration (optional) ──────────────────────────────────────
SALES_ARENA_API_URL=
SALES_ARENA_API_KEY=

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
